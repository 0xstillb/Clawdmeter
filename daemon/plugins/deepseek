#!/usr/bin/env python3
"""DeepSeek provider plugin for Clawdmeter.

DeepSeek is an API-only prepaid provider. It shows total used and remaining
credit in the same prepaid layout as OpenCode Zen. The first observed balance
fills the remaining bar; it then drains as credit is spent.

Fetches ``GET /user/balance`` directly.

UI Layout:
  - Top card: Used credit since the bar's current baseline
  - Bottom card: Remaining balance

Credentials (checked in order):
  1. DEEPSEEK_API_KEY or DEEPSEEK_KEY env var
  2. ~/.config/clawdmeter/deepseek-credentials.json (key: api_key)

Dependencies: httpx
Protocol: DAEMON_PLUGIN_PROTOCOL.md
"""

from __future__ import annotations

import asyncio
import json
import os
import sys
from datetime import date
from pathlib import Path

# Add repo root so imports work when run standalone
_REPO_ROOT = Path(__file__).resolve().parent.parent.parent
if str(_REPO_ROOT) not in sys.path:
    sys.path.insert(0, str(_REPO_ROOT))

import httpx

from daemon.plugin_protocol import PluginRequest, PluginResponse
from daemon.payloads import build_deepseek_usage_payload

# ── constants ───────────────────────────────────────────────────────────────

DEEPSEEK_BALANCE_URL = "https://api.deepseek.com/user/balance"
_USER_AGENT = "clawdmeter/1.0"
_TIMEOUT = 20.0
_STATE_DIR = Path.home() / ".config" / "clawdmeter"
_STATE_FILE = _STATE_DIR / "deepseek-state.json"


# ── helpers ─────────────────────────────────────────────────────────────────


def _debug(*args: object) -> None:
    """Emit debug log to stderr when --debug is passed."""
    if "--debug" in sys.argv:
        print("[deepseek]", *args, file=sys.stderr)


def _read_credentials() -> dict | None:
    """Return the API key from environment or saved settings."""
    api_key = os.environ.get("DEEPSEEK_API_KEY", "").strip() or os.environ.get("DEEPSEEK_KEY", "").strip()

    if api_key:
        _debug("using env credentials")
        return {"api_key": api_key}

    config_paths = [
        _STATE_DIR / "deepseek-credentials.json",
    ]
    for path in config_paths:
        try:
            data = json.loads(path.read_text(encoding="utf-8"))
        except (OSError, json.JSONDecodeError):
            continue
        api_key = data.get("api_key", "").strip()
        if not api_key:
            continue
        _debug(f"using credentials from {path}")
        return {"api_key": api_key}
    return None


def _is_auth_failure(msg: str | None) -> bool:
    """Return True if *msg* indicates a prior auth failure."""
    if not msg:
        return False
    lowered = msg.lower()
    return "api key" in lowered or "not configured" in lowered or "401" in msg or "403" in msg


def _read_state() -> dict | None:
    try:
        return json.loads(_STATE_FILE.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError):
        return None


def _write_state(state: dict) -> None:
    _STATE_DIR.mkdir(parents=True, exist_ok=True)
    _STATE_FILE.write_text(json.dumps(state, indent=2), encoding="utf-8")


def _minutes_until_midnight() -> int:
    import datetime as dt
    now = dt.datetime.now()
    tomorrow = now.replace(hour=0, minute=0, second=0, microsecond=0) + dt.timedelta(days=1)
    return int((tomorrow - now).total_seconds() / 60)


def _compute_balance_progress(current_balance: float) -> dict:
    """Keep a high-water balance so Remaining starts full and drains smoothly."""
    today = str(date.today())
    state = _read_state()
    try:
        baseline = float(state.get("bar_baseline", current_balance)) if state else current_balance
    except (TypeError, ValueError):
        baseline = current_balance
    # A top-up becomes the new full bar. Do not shrink its scale while spending.
    baseline = max(baseline, current_balance)

    if state is None or state.get("date") != today:
        _write_state({
            "date": today,
            "start_balance": current_balance,
            "bar_baseline": baseline,
        })
        return {"spent": max(0.0, baseline - current_balance), "baseline": baseline,
                "reset_mins": _minutes_until_midnight()}

    try:
        start_balance = float(state.get("start_balance", current_balance))
    except (TypeError, ValueError):
        start_balance = current_balance
    _write_state({
        "date": today,
        "start_balance": start_balance,
        "last_balance": current_balance,
        "bar_baseline": baseline,
    })
    return {"spent": max(0.0, baseline - current_balance), "baseline": baseline,
            "reset_mins": _minutes_until_midnight()}


# ── main poll logic ─────────────────────────────────────────────────────────


async def poll() -> PluginResponse:
    """Read PluginRequest, fetch DeepSeek balance, return PluginResponse."""
    req = PluginRequest.from_stdin()
    _debug(f"request: action={req.action}, last_error={req.last_error!r}")

    # ── credentials ────────────────────────────────────────────────────
    creds = _read_credentials()
    if creds is None:
        return PluginResponse.failure(
            "DeepSeek: API key not configured — set DEEPSEEK_API_KEY env var "
            "or create ~/.config/clawdmeter/deepseek-credentials.json",
            retry=False,
        )

    api_key = creds.get("api_key", "")
    if not api_key:
        return PluginResponse.failure(
            "DeepSeek: API key is empty", retry=False
        )

    # ── repeated auth failure → stop retrying ─────────────────────────
    if _is_auth_failure(req.last_error):
        _debug("repeated auth failure detected, returning retry:false")
        return PluginResponse.failure(
            "DeepSeek: API key invalid — please update your credentials",
            retry=False,
        )

    # ── fetch balance ──────────────────────────────────────────────────
    headers = {
        "Accept": "application/json",
        "Authorization": f"Bearer {api_key}",
        "User-Agent": _USER_AGENT,
    }

    try:
        async with httpx.AsyncClient(timeout=_TIMEOUT) as http:
            resp = await http.get(DEEPSEEK_BALANCE_URL, headers=headers)
    except httpx.HTTPError as e:
        _debug(f"HTTP request failed: {e}")
        return PluginResponse.failure(f"DeepSeek: Network error: {e}", retry=True)

    # ── HTTP response handling ─────────────────────────────────────────
    if resp.status_code in (401, 403):
        _debug(f"auth failed (HTTP {resp.status_code})")
        return PluginResponse.failure(
            f"DeepSeek: auth failed (HTTP {resp.status_code}) — API key may be invalid",
            retry=False,
        )

    if resp.status_code >= 400:
        _debug(f"HTTP {resp.status_code}: {resp.text[:200]}")
        return PluginResponse.failure(
            f"DeepSeek: HTTP {resp.status_code}", retry=True
        )

    # ── parse response ─────────────────────────────────────────────────
    try:
        body = resp.json()
    except json.JSONDecodeError:
        _debug("response was not JSON")
        return PluginResponse.failure(
            "DeepSeek: API returned invalid JSON", retry=True
        )

    if not isinstance(body, dict):
        return PluginResponse.failure(
            "DeepSeek: unexpected response format", retry=True
        )

    # ── validate balance response ─────────────────────────────────────
    infos = body.get("balance_infos", [])
    if not isinstance(infos, list) or not any(isinstance(item, dict) for item in infos):
        _debug("no balance_infos in response")
        return PluginResponse.failure(
            "DeepSeek: unexpected balance response format", retry=True
        )

    # ── build and return payload ───────────────────────────────────────
    balances = [item for item in infos if isinstance(item, dict)]
    ledger = next(
        (item for item in balances if str(item.get("currency", "")).upper() == "USD"),
        balances[0],
    )
    try:
        balance = max(0.0, float(ledger.get("total_balance", 0) or 0))
    except (TypeError, ValueError):
        balance = 0.0
    progress = _compute_balance_progress(balance)

    payload = build_deepseek_usage_payload(
        body,
        total_budget=progress["baseline"],
        total_spent=progress["spent"],
        daily_reset_mins=progress["reset_mins"],
    )
    return PluginResponse.success(payload)


async def main() -> None:
    result = await poll()
    print(result.to_json())


if __name__ == "__main__":
    asyncio.run(main())
