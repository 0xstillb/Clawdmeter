#!/usr/bin/env python3
"""DeepSeek provider plugin for Clawdmeter.

DeepSeek is a **prepaid** (เติมเงิน) provider — usage is tracked via
remaining balance, not rate-limit headers.

Fetches ``GET /user/balance`` and returns a payload with ``plan_type: prepaid``
so the ESP32 firmware renders balance info instead of usage windows.

Credentials (checked in order):
  1. DEEPSEEK_API_KEY env var
  2. ~/.config/clawdmeter/deepseek-credentials.json (keys: api_key, total_top_up)

``total_top_up`` is optional. If set, the plugin computes
``used_pct = (total_top_up - current_topped_up) / total_top_up * 100``.
Without it, the plugin just reports the raw balance.

Dependencies: httpx
Protocol: DAEMON_PLUGIN_PROTOCOL.md
"""

from __future__ import annotations

import asyncio
import json
import os
import sys
import time
from pathlib import Path

# Add repo root so imports work when run standalone
_REPO_ROOT = Path(__file__).resolve().parent.parent.parent
if str(_REPO_ROOT) not in sys.path:
    sys.path.insert(0, str(_REPO_ROOT))

import httpx

from daemon.plugin_protocol import PluginRequest, PluginResponse
from daemon.payloads import build_deepseek_usage_payload

# ── constants ───────────────────────────────────────────────────────────────

DEEPSEEK_BALANCE_URL = "https://api.deepseek.com/user/balance"
_USER_AGENT = "clawdmeter/1.0"
_TIMEOUT = 20.0


# ── helpers ─────────────────────────────────────────────────────────────────


def _debug(*args: object) -> None:
    """Emit debug log to stderr when --debug is passed."""
    if "--debug" in sys.argv:
        print("[deepseek]", *args, file=sys.stderr)


def _read_credentials() -> dict | None:
    """Return {api_key, total_top_up} from env or config file.

    ``total_top_up`` is optional — can be 0 or None.
    """
    api_key = os.environ.get("DEEPSEEK_API_KEY", "").strip()
    total_top_up_str = os.environ.get("DEEPSEEK_TOTAL_TOP_UP", "").strip()

    if api_key:
        total_top_up = 0.0
        if total_top_up_str:
            try:
                total_top_up = float(total_top_up_str)
            except ValueError:
                pass
        _debug("using env credentials")
        return {"api_key": api_key, "total_top_up": total_top_up}

    config_paths = [
        Path.home() / ".config" / "clawdmeter" / "deepseek-credentials.json",
    ]
    for path in config_paths:
        try:
            data = json.loads(path.read_text(encoding="utf-8"))
        except (OSError, json.JSONDecodeError):
            continue
        api_key = data.get("api_key", "").strip()
        if not api_key:
            continue
        total_top_up = 0.0
        raw = data.get("total_top_up")
        if raw:
            try:
                total_top_up = float(raw)
            except (TypeError, ValueError):
                pass
        _debug(f"using credentials from {path}")
        return {"api_key": api_key, "total_top_up": total_top_up}
    return None


def _is_auth_failure(msg: str | None) -> bool:
    """Return True if *msg* indicates a prior auth failure."""
    if not msg:
        return False
    lowered = msg.lower()
    return "api key" in lowered or "not configured" in lowered or "401" in msg or "403" in msg


# ── main poll logic ─────────────────────────────────────────────────────────


async def poll() -> PluginResponse:
    """Read PluginRequest, fetch DeepSeek balance, return PluginResponse."""
    req = PluginRequest.from_stdin()
    _debug(f"request: action={req.action}, last_error={req.last_error!r}")

    # ── credentials ────────────────────────────────────────────────────
    creds = _read_credentials()
    if creds is None:
        return PluginResponse.failure(
            "DeepSeek: API key not configured — set DEEPSEEK_API_KEY env var "
            "or create ~/.config/clawdmeter/deepseek-credentials.json",
            retry=False,
        )

    api_key = creds.get("api_key", "")
    total_top_up = creds.get("total_top_up", 0.0)
    if not api_key:
        return PluginResponse.failure(
            "DeepSeek: API key is empty", retry=False
        )

    # ── repeated auth failure → stop retrying ─────────────────────────
    if _is_auth_failure(req.last_error):
        _debug("repeated auth failure detected, returning retry:false")
        return PluginResponse.failure(
            "DeepSeek: API key invalid — please update your credentials",
            retry=False,
        )

    # ── fetch balance ──────────────────────────────────────────────────
    headers = {
        "Accept": "application/json",
        "Authorization": f"Bearer {api_key}",
        "User-Agent": _USER_AGENT,
    }

    try:
        async with httpx.AsyncClient(timeout=_TIMEOUT) as http:
            resp = await http.get(DEEPSEEK_BALANCE_URL, headers=headers)
    except httpx.HTTPError as e:
        _debug(f"HTTP request failed: {e}")
        return PluginResponse.failure(f"DeepSeek: Network error: {e}", retry=True)

    # ── HTTP response handling ─────────────────────────────────────────
    if resp.status_code in (401, 403):
        _debug(f"auth failed (HTTP {resp.status_code})")
        return PluginResponse.failure(
            f"DeepSeek: auth failed (HTTP {resp.status_code}) — API key may be invalid",
            retry=False,
        )

    if resp.status_code >= 400:
        _debug(f"HTTP {resp.status_code}: {resp.text[:200]}")
        return PluginResponse.failure(
            f"DeepSeek: HTTP {resp.status_code}", retry=True
        )

    # ── parse response ─────────────────────────────────────────────────
    try:
        body = resp.json()
    except json.JSONDecodeError:
        _debug("response was not JSON")
        return PluginResponse.failure(
            "DeepSeek: API returned invalid JSON", retry=True
        )

    if not isinstance(body, dict):
        return PluginResponse.failure(
            "DeepSeek: unexpected response format", retry=True
        )

    # ── build and return payload ───────────────────────────────────────
    payload = build_deepseek_usage_payload(body, now=time.time(), total_top_up=total_top_up)
    return PluginResponse.success(payload)


async def main() -> None:
    result = await poll()
    print(result.to_json())


if __name__ == "__main__":
    asyncio.run(main())
