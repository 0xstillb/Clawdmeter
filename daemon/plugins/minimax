#!/usr/bin/env python3
"""MiniMax provider plugin for Clawdmeter.

Polls the MiniMax API for usage data and returns a BLE payload.

MiniMax rate-limit info is returned in the response body under ``usage``
rather than HTTP headers.  This plugin makes a minimal chat completion call
to extract that data.

Credentials (checked in order):
  1. MINIMAX_API_KEY env var
  2. MINIMAX_GROUP_ID env var (required alongside API key)
  3. ~/.config/clawdmeter/minimax-credentials.json (keys: api_key, group_id)

Dependencies: httpx
Protocol: DAEMON_PLUGIN_PROTOCOL.md
"""

from __future__ import annotations

import asyncio
import json
import os
import sys
import time
from pathlib import Path

# Add repo root so imports work when run standalone
_REPO_ROOT = Path(__file__).resolve().parent.parent.parent
if str(_REPO_ROOT) not in sys.path:
    sys.path.insert(0, str(_REPO_ROOT))

import httpx

from daemon.plugin_protocol import PluginRequest, PluginResponse
from daemon.payloads import build_minimax_usage_payload

# ── constants ───────────────────────────────────────────────────────────────

MINIMAX_CHAT_URL = "https://api.minimax.chat/v1/text/chatcompletion"
_USER_AGENT = "clawdmeter/1.0"
_TIMEOUT = 20.0

# A minimal payload to elicit usage info without generating meaningful output.
_API_BODY = {
    "model": "minimax-text-01",
    "tokens_to_generate": 1,
    "messages": [{"sender_type": "USER", "sender_name": "user", "text": "hi"}],
}


# ── helpers ─────────────────────────────────────────────────────────────────


def _debug(*args: object) -> None:
    """Emit debug log to stderr when --debug is passed."""
    if "--debug" in sys.argv:
        print("[minimax]", *args, file=sys.stderr)


def _read_credentials() -> dict | None:
    """Return {api_key, group_id} from env or config file."""
    api_key = os.environ.get("MINIMAX_API_KEY", "").strip()
    group_id = os.environ.get("MINIMAX_GROUP_ID", "").strip()

    if api_key and group_id:
        _debug("using env credentials")
        return {"api_key": api_key, "group_id": group_id}

    config_paths = [
        Path.home() / ".config" / "clawdmeter" / "minimax-credentials.json",
    ]
    for path in config_paths:
        try:
            data = json.loads(path.read_text(encoding="utf-8"))
        except (OSError, json.JSONDecodeError):
            continue
        api_key = data.get("api_key", "").strip() or api_key
        group_id = data.get("group_id", "").strip() or group_id
        if api_key and group_id:
            _debug(f"using credentials from {path}")
            return {"api_key": api_key, "group_id": group_id}
    return None


def _is_auth_failure(msg: str | None) -> bool:
    """Return True if *msg* indicates a prior auth failure."""
    if not msg:
        return False
    lowered = msg.lower()
    return "api key" in lowered or "not configured" in lowered or "401" in msg or "403" in msg


# ── main poll logic ─────────────────────────────────────────────────────────


async def poll() -> PluginResponse:
    """Read PluginRequest, poll MiniMax API, return PluginResponse."""
    req = PluginRequest.from_stdin()
    _debug(f"request: action={req.action}, last_error={req.last_error!r}")

    # ── credentials ────────────────────────────────────────────────────
    creds = _read_credentials()
    if creds is None:
        return PluginResponse.failure(
            "MiniMax: credentials not configured — set MINIMAX_API_KEY and "
            "MINIMAX_GROUP_ID env vars, or create "
            "~/.config/clawdmeter/minimax-credentials.json",
            retry=False,
        )

    api_key = creds.get("api_key", "")
    group_id = creds.get("group_id", "")
    if not api_key or not group_id:
        return PluginResponse.failure(
            "MiniMax: credentials incomplete (missing api_key or group_id)",
            retry=False,
        )

    # ── repeated auth failure → stop retrying ─────────────────────────
    if _is_auth_failure(req.last_error):
        _debug("repeated auth failure, returning retry:false")
        return PluginResponse.failure(
            "MiniMax: API key invalid — please update your credentials",
            retry=False,
        )

    # ── minimal API call ─────────────────────────────────────────────
    headers = {
        "Authorization": f"Bearer {api_key}",
        "Content-Type": "application/json",
        "User-Agent": _USER_AGENT,
    }
    url = f"{MINIMAX_CHAT_URL}?GroupId={group_id}"

    try:
        async with httpx.AsyncClient(timeout=_TIMEOUT) as http:
            resp = await http.post(url, headers=headers, json=_API_BODY)
    except httpx.HTTPError as e:
        _debug(f"HTTP request failed: {e}")
        return PluginResponse.failure(f"MiniMax: Network error: {e}", retry=True)

    # ── HTTP response handling ─────────────────────────────────────────
    if resp.status_code in (401, 403):
        _debug(f"auth failed (HTTP {resp.status_code})")
        return PluginResponse.failure(
            f"MiniMax: auth failed (HTTP {resp.status_code}) — API key may be invalid",
            retry=False,
        )

    if resp.status_code == 429:
        _debug("rate limited (HTTP 429)")
        payload = build_minimax_usage_payload(
            {"usage": {"rate_limit_pct": 100, "daily_usage_pct": 0}},
            now=time.time(),
        )
        return PluginResponse.success(payload)

    if resp.status_code >= 400:
        _debug(f"HTTP {resp.status_code}: {resp.text[:200]}")
        return PluginResponse.failure(
            f"MiniMax: HTTP {resp.status_code}", retry=True
        )

    # ── parse response body ────────────────────────────────────────────
    try:
        body = resp.json()
    except json.JSONDecodeError:
        _debug("response was not JSON")
        return PluginResponse.failure(
            "MiniMax: API returned invalid JSON", retry=True
        )

    if not isinstance(body, dict):
        return PluginResponse.failure(
            "MiniMax: unexpected response format", retry=True
        )

    # ── build and return payload ───────────────────────────────────────
    payload = build_minimax_usage_payload(body, now=time.time())
    return PluginResponse.success(payload)


async def main() -> None:
    result = await poll()
    print(result.to_json())


if __name__ == "__main__":
    asyncio.run(main())
