#!/usr/bin/env python3
"""MiniMax Coding Plan provider plugin for Clawdmeter.

Polls MiniMax's dedicated Coding Plan quota endpoint.  It deliberately does
not send a chat-completion request: that endpoint no longer returns plan quota
and could consume a request just to update the display.

Credentials (checked in order):
  1. MINIMAX_CODING_API_KEY or MINIMAX_API_KEY env var (``sk-cp-*``)
  2. ~/.config/clawdmeter/minimax-credentials.json (key: api_key)


Dependencies: httpx
Protocol: DAEMON_PLUGIN_PROTOCOL.md
"""

from __future__ import annotations

import asyncio
import json
import os
import sys
import time
from pathlib import Path

# Add repo root so imports work when run standalone
_REPO_ROOT = Path(__file__).resolve().parent.parent.parent
if str(_REPO_ROOT) not in sys.path:
    sys.path.insert(0, str(_REPO_ROOT))

import httpx

from daemon.plugin_protocol import PluginRequest, PluginResponse
from daemon.payloads import build_minimax_usage_payload

# ── constants ───────────────────────────────────────────────────────────────

MINIMAX_REMAINS_URLS = (
    "https://api.minimax.io/v1/token_plan/remains",
    "https://www.minimax.io/v1/token_plan/remains",
    "https://api.minimaxi.com/v1/token_plan/remains",
    "https://www.minimaxi.com/v1/token_plan/remains",
)
_USER_AGENT = "clawdmeter/1.0"
_TIMEOUT = 20.0


# ── helpers ─────────────────────────────────────────────────────────────────


def _debug(*args: object) -> None:
    """Emit debug log to stderr when --debug is passed."""
    if "--debug" in sys.argv:
        print("[minimax]", *args, file=sys.stderr)


def _read_credentials() -> dict | None:
    """Return the Coding Plan API key from environment or tray settings."""
    api_key = (
        os.environ.get("MINIMAX_CODING_API_KEY", "").strip()
        or os.environ.get("MINIMAX_API_KEY", "").strip()
    )
    if api_key:
        _debug("using env credentials")
        return {"api_key": api_key}

    config_paths = [
        Path.home() / ".config" / "clawdmeter" / "minimax-credentials.json",
    ]
    for path in config_paths:
        try:
            data = json.loads(path.read_text(encoding="utf-8"))
        except (OSError, json.JSONDecodeError):
            continue
        api_key = data.get("api_key", "").strip() or api_key
        if api_key:
            _debug(f"using credentials from {path}")
            return {"api_key": api_key}
    return None


def _is_auth_failure(msg: str | None) -> bool:
    """Return True if *msg* indicates a prior auth failure."""
    if not msg:
        return False
    lowered = msg.lower()
    return "api key" in lowered or "not configured" in lowered or "401" in msg or "403" in msg


def _remains_urls() -> tuple[str, ...]:
    """Return the official Coding Plan quota endpoints to try."""
    return MINIMAX_REMAINS_URLS


def _api_error(body: object) -> str | None:
    """Extract a safe API error from the two MiniMax response envelopes."""
    if not isinstance(body, dict):
        return "unexpected response format"
    envelope = body.get("data") if isinstance(body.get("data"), dict) else body
    status = body.get("base_resp") or envelope.get("base_resp")
    if not isinstance(status, dict):
        return None
    code = status.get("status_code")
    if code in (None, 0, "0"):
        return None
    return str(status.get("status_msg") or f"status_code {code}")


# ── main poll logic ─────────────────────────────────────────────────────────


async def poll() -> PluginResponse:
    """Read PluginRequest, poll MiniMax API, return PluginResponse."""
    req = PluginRequest.from_stdin()
    _debug(f"request: action={req.action}, last_error={req.last_error!r}")

    # ── credentials ────────────────────────────────────────────────────
    creds = _read_credentials()
    if creds is None:
        return PluginResponse.failure(
            "MiniMax: Coding Plan API key not configured — set "
            "MINIMAX_CODING_API_KEY or MINIMAX_API_KEY, or create "
            "~/.config/clawdmeter/minimax-credentials.json",
            retry=False,
        )

    api_key = creds.get("api_key", "")
    if not api_key:
        return PluginResponse.failure(
            "MiniMax: credentials incomplete (missing Coding Plan API key)",
            retry=False,
        )

    # ── repeated auth failure → stop retrying ─────────────────────────
    if _is_auth_failure(req.last_error):
        _debug("repeated auth failure, returning retry:false")
        return PluginResponse.failure(
            "MiniMax: API key invalid — please update your credentials",
            retry=False,
        )

    # ── Coding Plan quota API ─────────────────────────────────────────
    headers = {
        "Authorization": f"Bearer {api_key}",
        "Content-Type": "application/json",
        "Accept": "application/json",
        "MM-API-Source": "Clawdmeter",
        "User-Agent": _USER_AGENT,
    }
    last_status: int | None = None
    saw_auth_failure = False
    try:
        async with httpx.AsyncClient(timeout=_TIMEOUT) as http:
            for url in _remains_urls():
                resp = await http.get(url, headers=headers)
                last_status = resp.status_code

                if resp.status_code == 200:
                    try:
                        body = resp.json()
                    except json.JSONDecodeError:
                        _debug(f"{url}: response was not JSON")
                        continue
                    error = _api_error(body)
                    if error:
                        _debug(f"{url}: API error {error}")
                        if "key" in error.lower() or "auth" in error.lower():
                            saw_auth_failure = True
                            continue
                        return PluginResponse.failure(f"MiniMax: {error}", retry=True)
                    if not isinstance(body, dict):
                        continue
                    return PluginResponse.success(build_minimax_usage_payload(body, now=time.time()))

                if resp.status_code in (401, 403):
                    saw_auth_failure = True
                    _debug(f"{url}: auth failed (HTTP {resp.status_code})")
                    continue
                if resp.status_code in (404, 405):
                    _debug(f"{url}: unavailable (HTTP {resp.status_code})")
                    continue
                if resp.status_code == 429:
                    _debug(f"{url}: rate limited")
                    return PluginResponse.success(
                        build_minimax_usage_payload(
                            {"usage": {"rate_limit_pct": 100, "daily_usage_pct": 0}},
                            now=time.time(),
                        )
                    )
                _debug(f"{url}: HTTP {resp.status_code}: {resp.text[:200]}")
    except httpx.HTTPError as e:
        _debug(f"HTTP request failed: {e}")
        return PluginResponse.failure(f"MiniMax: Network error: {e}", retry=True)

    if saw_auth_failure:
        return PluginResponse.failure(
            "MiniMax: Coding Plan API key was rejected — use an sk-cp-* key",
            retry=False,
        )
    return PluginResponse.failure(
        f"MiniMax: Coding Plan quota endpoint unavailable (HTTP {last_status or 'network'})",
        retry=True,
    )


async def main() -> None:
    result = await poll()
    print(result.to_json())


if __name__ == "__main__":
    asyncio.run(main())
